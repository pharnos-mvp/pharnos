# Headers HTTP servis par Cloudflare Pages (copié dans dist/ par Vite, comme _redirects).
# Doc format : https://developers.cloudflare.com/pages/configuration/headers/
#
# CSP — justification des directives non triviales :
# - script-src 'self' strict : AUCUN script inline dans le build (vérifié : index-*.js et
#   registerSW.js sont des fichiers same-origin). Pas de nonce/hash nécessaire.
# - 'wasm-unsafe-eval' : pdf.js v6 charge des décodeurs WASM (openjpeg/qcms) pour certains
#   PDF scannés — sans ça l'aperçu de ces PDF casse silencieusement.
# - style-src 'unsafe-inline' : <style> inline du squelette app-shell (index.html) + attributs
#   style posés par TipTap/Radix/textAlign. Les hash CSP ne couvrent pas les attributs style.
#   Risque résiduel faible car script-src reste strict.
# - worker-src 'self' blob: : service worker Workbox (/sw.js) + worker pdf.js (asset same-origin
#   chargé via ?url) ; blob: pour le fallback fake-worker de pdf.js.
# - connect-src : API Supabase (REST + Auth + Storage + Edge Functions, même domaine) + Sentry.
# - frame-ancestors 'none' : aucune iframe dans l'app (PDF rendu en canvas), anti-clickjacking.
#
# CSP ENFORCÉE (T1 phase 2) — validée en Report-Only : 0 violation observée (app-shell, SW,
# chunks, login). Rollback : repasser cette ligne en Content-Security-Policy-Report-Only.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://uhsireqwzqqymgsxuvqh.supabase.co https://*.sentry.io; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin

# Assets fingerprintés par Vite (hash dans le nom) → cache long immuable.
# Gros gain de perf en visite répétée / réseau lent (zéro revalidation).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Le service worker et son registreur doivent TOUJOURS être revalidés, sinon les mises à
# jour de l'app ne se propagent plus (le SW contrôle tout le cache applicatif).
/sw.js
  Cache-Control: no-cache

/registerSW.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache
